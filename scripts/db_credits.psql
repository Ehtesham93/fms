-- Credit wallet 
CREATE TABLE
    credit_wallet (
        accountid uuid NOT NULL REFERENCES accounts (accountid) ON DELETE CASCADE,
        walletid uuid DEFAULT uuid_generate_v4 (),
        total_credits NUMERIC(20, 3) NOT NULL DEFAULT 0,
        available_credits NUMERIC(20, 3) NOT NULL DEFAULT 0,
        reserved_credits NUMERIC(20, 3) NOT NULL DEFAULT 0,
        credits_expires_at TIMESTAMPTZ DEFAULT (now() + INTERVAL '3 years'),
        createdby uuid NULL REFERENCES users (userid) ON DELETE CASCADE,
        createdat TIMESTAMPTZ NOT NULL DEFAULT now(),
        updatedby uuid NULL REFERENCES users (userid) ON DELETE CASCADE,
        updatedat TIMESTAMPTZ NOT NULL DEFAULT now(),
        PRIMARY KEY (accountid, walletid),
        UNIQUE (walletid)
    );

CREATE INDEX ix_credit_wallet_id ON credit_wallet (walletid);

-- Monetisation entry
-- credit_purchase focuses on cash (currency, tax, reconciliation with the bank)
CREATE TABLE
    credit_purchase (
        accountid uuid NOT NULL REFERENCES accounts (accountid) ON DELETE CASCADE,
        purchaseid uuid DEFAULT uuid_generate_v4 (),
        credits_purchased NUMERIC(20, 3) NOT NULL,
        gross_amount NUMERIC(20, 3) NOT NULL,
        currency CHAR(3) NOT NULL DEFAULT 'INR',
        invoiceid uuid NULL REFERENCES invoices (invoiceid) ON DELETE CASCADE,
        status TEXT NOT NULL DEFAULT 'captured' CHECK (
            status IN (
                'auth',
                'captured',
                'failed',
                'refunded',
                'other',
                'voided',
                'pending',
                'expired'
            )
        ),
        paymentinfo jsonb NOT NULL,
        purchaseinfo jsonb NOT NULL,
        createdby uuid NULL REFERENCES users (userid) ON DELETE CASCADE,
        createdat TIMESTAMPTZ NOT NULL DEFAULT now(),
        updatedby uuid NULL REFERENCES users (userid) ON DELETE CASCADE,
        updatedat TIMESTAMPTZ NOT NULL DEFAULT now(),
        captured_at TIMESTAMPTZ NOT NULL DEFAULT now(),
        PRIMARY KEY (accountid, purchaseid)
    );

CREATE INDEX ix_credit_purchase_id ON credit_purchase (purchaseid);

-- Double-entry ledger
-- credit_transaction focuses on credits (non-monetary internal units) and keeps a complete, append-only audit trail of every change to the wallet balance. Can go to 100M+ rows.
CREATE TABLE
    credit_transaction (
        accountid uuid NOT NULL REFERENCES accounts (accountid) ON DELETE CASCADE,
        walletid uuid NOT NULL REFERENCES credit_wallet (walletid) ON DELETE CASCADE,
        txnid uuid DEFAULT uuid_generate_v4 (),
        txntype TEXT NOT NULL CHECK (
            txntype IN ('purchase', 'burn', 'refund', 'adjust')
        ),
        txninfo jsonb NOT NULL,
        pkgid uuid NOT NULL REFERENCES subscriptionpkgs (subscriptionpkgid) ON DELETE CASCADE,
        num_sub_vehicles INTEGER NOT NULL,
        num_connected_vehicles INTEGER NOT NULL,
        credit_delta NUMERIC(20, 3) NOT NULL, -- positive in case of purchase, refund; negative in case of burn; positive or negative in case of adjust
        ref_table TEXT NULL, -- refers to credit_purchase table in case of purchase, refund; null in case of burn, adjust
        refid uuid NULL REFERENCES credit_purchase (purchaseid) ON DELETE CASCADE, -- purchaseid in case of purchase, refund; null in case of burn, adjust
        remarks TEXT NULL,
        createdat TIMESTAMPTZ NOT NULL DEFAULT now(),
        createdby uuid NOT NULL REFERENCES users (userid) ON DELETE CASCADE DEFERRABLE INITIALLY DEFERRED,
        PRIMARY KEY (accountid, walletid, txnid),
        UNIQUE (txnid),
        FOREIGN KEY (accountid, walletid) REFERENCES credit_wallet (accountid, walletid) ON DELETE CASCADE
    );

CREATE INDEX ix_credit_txn_wallet ON credit_transaction (walletid);

CREATE INDEX ix_credit_txn_created ON credit_transaction (createdat DESC);

