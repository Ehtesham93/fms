        isactive boolean NOT NULL DEFAULT true,
        CONSTRAINT valid_email CHECK (
            contactemail IS NULL
            OR contactemail ~ '^[^\s@]+@[^\s@]+\.[^\s@]+$'
        ),
        CONSTRAINT valid_priority CHECK (
            priority >= 1
            AND priority <= 5
        )
    );

