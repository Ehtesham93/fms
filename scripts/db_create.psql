    );

-- Create view for fleet_user_perm based on user roles and permissions
-- This view combines fleet_user_role and role_perm to provide user permissions at the fleet level
CREATE OR REPLACE VIEW
    fleet_user_perm AS
SELECT DISTINCT
    fur.accountid,
    fur.fleetid,
    fur.userid,
    rp.permid,
    rp.isenabled,
    rp.createdat,
    rp.createdby
FROM
    fleet_user_role fur
    JOIN role_perm rp ON fur.accountid = rp.accountid
    AND fur.roleid = rp.roleid
WHERE
    rp.isenabled = true;

-- Add comment to explain the view
COMMENT ON VIEW fleet_user_perm IS 'View that provides user permissions at the fleet level by joining fleet_user_role with role_perm. This view is used in permission checking functions to determine what permissions a user has for specific fleets.';

-- Create index on the underlying tables for better performance
CREATE INDEX IF NOT EXISTS idx_fleet_user_role_accountid_fleetid_userid ON fleet_user_role (accountid, fleetid, userid);

CREATE INDEX IF NOT EXISTS idx_role_perm_accountid_roleid_permid ON role_perm (accountid, roleid, permid)
WHERE
    isenabled = true;

-- Functions
CREATE
OR REPLACE FUNCTION refresh_platform_user_role_mv () RETURNS TRIGGER AS $$
BEGIN
    -- For INSERT/UPDATE operations
    IF (TG_OP = 'INSERT' OR TG_OP = 'UPDATE') THEN
        IF NEW.accountid = 'ffffffff-ffff-ffff-ffff-ffffffffffff' THEN
            BEGIN
                REFRESH MATERIALIZED VIEW CONCURRENTLY platform_user_role_mv;
            EXCEPTION
                WHEN OTHERS THEN
                    -- If CONCURRENTLY fails, try without it
                    REFRESH MATERIALIZED VIEW platform_user_role_mv;
            END;
        END IF;
    -- For DELETE operations
    ELSIF (TG_OP = 'DELETE') THEN
        IF OLD.accountid = 'ffffffff-ffff-ffff-ffff-ffffffffffff' THEN
            BEGIN
                REFRESH MATERIALIZED VIEW CONCURRENTLY platform_user_role_mv;
            EXCEPTION
                WHEN OTHERS THEN
                    -- If CONCURRENTLY fails, try without it
                    REFRESH MATERIALIZED VIEW platform_user_role_mv;
            END;
        END IF;
    END IF;
    
    -- Return appropriate value based on operation
    IF TG_OP = 'DELETE' THEN
        RETURN OLD;
    ELSE
        RETURN NEW;
    END IF;
END;
$$ LANGUAGE plpgsql;

CREATE
OR REPLACE FUNCTION get_sub_fleet_tree (useridarg uuid, accountidarg uuid, permidarg text) RETURNS TABLE (
    accountid uuid,
    pfleetid uuid,
    fleetid uuid,
    name text,
    depth bigint,
    isdeleted bool
) language sql as $$
with recursive parent as (
    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, ft.isdeleted, 1 as depth from fleet_tree ft
    join user_fleet uf on ft.accountid = uf.accountid and uf.fleetid = uf.fleetid
    join fleet_user_perm fup on uf.accountid = fup.accountid and uf.fleetid = fup.fleetid and uf.userid = fup.userid
    where uf.accountid = accountidarg and uf.userid = useridarg and fup.permid = permidarg

    union all

    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, ft.isdeleted, p.depth + 1 from fleet_tree ft
    join parent p on ft.accountid = p.accountid and p.fleetid = ft.pfleetid
)
select p.accountid, p.pfleetid, p.fleetid, p.name, p.depth, p.isdeleted from parent p
order by depth
$$;

CREATE
OR REPLACE FUNCTION get_parent_fleet_path ( -- note: no need to check perm here. b/c we are using it as path-prefix
    useridarg uuid,
    accountidarg uuid,
    rootparentfleetidarg uuid
) RETURNS TABLE (path text, leafid uuid) language sql as $$
with recursive children as (

    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, ft.name as path, 1 as height, ft.fleetid as leafid from fleet_tree ft
    join user_fleet uf on ft.accountid = uf.accountid and ft.fleetid = uf.fleetid
    where uf.accountid = accountidarg and uf.userid = useridarg

    union all

    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, ft.name || '/' || c.path as path,
           c.height + 1, c.leafid from fleet_tree ft
    join children c on ft.accountid = c.accountid and c.pfleetid = ft.fleetid
)

select c.path, c.leafid from children c
    where c.pfleetid = rootparentfleetidarg
    order by height
$$;

CREATE
OR REPLACE FUNCTION get_parent_fleet_ids_with_perm (
    useridarg uuid,
    accountidarg uuid,
    fleetidarg uuid,
    permidarg text
) RETURNS TABLE (fleetid uuid, permid text) language sql as $$
    with recursive children as (

        select ft.accountid, ft.pfleetid, ft.fleetid, 1 as height from fleet_tree ft
        where ft.accountid = accountidarg and ft.fleetid = fleetidarg

        union all

        select ft.accountid, ft.pfleetid, ft.fleetid, c.height + 1 from fleet_tree ft
        join children c on ft.accountid = c.accountid and c.pfleetid = ft.fleetid
    )

    select c.fleetid, fup.permid from children c
    left join fleet_user_perm fup on c.accountid = fup.accountid and c.fleetid = fup.fleetid
    where fup.userid = useridarg and fup.permid = permidarg
    order by c.height desc
$$;

-- given fleetid, userid; check if user has set of accesses anywhere in ptree
CREATE
OR REPLACE FUNCTION check_fleet_perms (
    accountidarg uuid,
    fleetidarg uuid,
    useridarg uuid,
    permidsarg text[]
) RETURNS int language sql as $$
    with recursive children as (
        select accountid, pfleetid, fleetid from fleet_tree
        where accountid = accountidarg and fleetid = fleetidarg

        union all

        select ft.accountid, ft.pfleetid, ft.fleetid from fleet_tree ft
        join children c on ft.accountid = c.accountid and ft.fleetid = c.pfleetid
    )

    select count(*) from children c
    join fleet_user_perm fup on c.accountid = fup.accountid and c.fleetid = fup.fleetid
    where fup.accountid = accountidarg and fup.userid = useridarg and fup.permid = any (permidsarg)
$$;

CREATE
OR REPLACE FUNCTION check_fleet_perm (
    accountidarg uuid,
    fleetidarg uuid,
    useridarg uuid,
    permidarg text
) RETURNS int language sql as $$
    with recursive children as (
        select accountid, pfleetid, fleetid from fleet_tree
        where accountid = accountidarg and fleetid = fleetidarg

        union all

        select ft.accountid, ft.pfleetid, ft.fleetid from fleet_tree ft
        join children c on ft.accountid = c.accountid and ft.fleetid = c.pfleetid
    )

    select count(*) from children c
    join fleet_user_perm fup on c.accountid = fup.accountid and c.fleetid = fup.fleetid
    where fup.accountid = accountidarg and fup.userid = useridarg and fup.permid = permidarg
$$;

CREATE
OR REPLACE FUNCTION get_all_fleets ( -- without perm
    accountidarg uuid,
    fleetidarg uuid
) RETURNS TABLE (fleetid uuid) language sql as $$
    with recursive children as (
        select accountid, pfleetid, fleetid from fleet_tree
        where accountid = accountidarg and fleetid = fleetidarg

        union all

        select ft.accountid, ft.pfleetid, ft.fleetid from fleet_tree ft
        join children c on ft.accountid = c.accountid and ft.pfleetid = c.fleetid
    )

    select fleetid from children;
$$;

CREATE
OR REPLACE FUNCTION get_sub_fleets_with_perm (
    accountidarg uuid,
    fleetidarg uuid,
    useridarg uuid,
    permidarg text
) RETURNS uuid language sql as $$
    with recursive children as (
        select accountid, pfleetid, fleetid from fleet_tree
        where accountid = accountidarg and fleetid = fleetidarg

        union all

        select ft.accountid, ft.pfleetid, ft.fleetid from fleet_tree ft
        join children c on ft.accountid = c.accountid and ft.pfleetid = c.fleetid
    )

    select c.fleetid from children c
    join fleet_user_perm fup on c.accountid = fup.accountid and c.fleetid =  fup.fleetid
    where fup.userid = useridarg and fup.permid = permidarg;
$$;

CREATE TABLE IF NOT EXISTS
    charge_deviation (
        deviation_code TEXT PRIMARY KEY,
        deviation_text TEXT NOT NULL
    );

