-- Views
CREATE OR REPLACE VIEW
    public_api_call_stats AS
SELECT
    endpoint,
    method,
    requestkey,
    count(*) AS total_calls,
    count(
        CASE
            WHEN (issuccess = true) THEN 1
            ELSE NULL::integer
        END
    ) AS success_calls,
    count(
        CASE
            WHEN (issuccess = false) THEN 1
            ELSE NULL::integer
        END
    ) AS failed_calls,
    round(
        (
            (
                (
                    count(
                        CASE
                            WHEN (issuccess = true) THEN 1
                            ELSE NULL::integer
                        END
                    )
                )::numeric / (count(*))::numeric
            ) * (100)::numeric
        ),
        2
    ) AS success_rate_percent,
    avg(processingtimems) AS avg_processing_time_ms,
    max(processingtimems) AS max_processing_time_ms,
    count(DISTINCT requestvalue) AS unique_identifiers,
    count(DISTINCT ipaddress) AS unique_ips,
    min(createdat) AS first_call,
    max(createdat) AS last_call
FROM
    public_api_audit_log
GROUP BY
    endpoint,
    method,
    requestkey
ORDER BY
    (count(*)) DESC;

CREATE OR REPLACE VIEW
    public_api_failed_calls AS
SELECT
    auditid,
    endpoint,
    method,
    statuscode,
    requestkey,
    requestvalue,
    errorcode,
    ipaddress,
    createdat
FROM
    public_api_audit_log
WHERE
    (issuccess = false)
ORDER BY
    createdat DESC;

CREATE OR REPLACE VIEW
    public_api_user_activity AS
SELECT
    requestkey,
    requestvalue,
    count(*) AS total_requests,
    count(
        CASE
            WHEN (issuccess = true) THEN 1
            ELSE NULL::integer
        END
    ) AS successful_requests,
    count(
        CASE
            WHEN (issuccess = false) THEN 1
            ELSE NULL::integer
        END
    ) AS failed_requests,
    count(DISTINCT endpoint) AS unique_endpoints,
    count(DISTINCT ipaddress) AS unique_ips,
    min(createdat) AS first_activity,
    max(createdat) AS last_activity
FROM
    public_api_audit_log
WHERE
    (
        (requestkey IS NOT NULL)
        AND (requestvalue IS NOT NULL)
    )
GROUP BY
    requestkey,
    requestvalue
ORDER BY
    (count(*)) DESC;

CREATE OR REPLACE VIEW
    user_login_stats AS
SELECT
    ssotype,
    loginattempt,
    COUNT(*) as attempt_count,
    COUNT(DISTINCT userid) as unique_users,
    DATE_TRUNC('hour', createdat) as hour_bucket
FROM
    user_login_audit
WHERE
    createdat >= NOW() - INTERVAL '24 hours'
GROUP BY
    ssotype,
    loginattempt,
    DATE_TRUNC('hour', createdat)
ORDER BY
    hour_bucket DESC;

CREATE OR REPLACE VIEW
    locked_users_summary AS
SELECT
    uls.userid,
    u.displayname,
    u.usertype,
    uls.consecutivefailedcount,
    uls.lastinvalidlogin,
    uls.lockeduntil,
    CASE
        WHEN uls.lockeduntil > NOW() THEN 'LOCKED'
        ELSE 'UNLOCKED'
    END as current_status
FROM
    user_login_security uls
    JOIN users u ON uls.userid = u.userid
WHERE
    uls.islocked = true
ORDER BY
    uls.lastinvalidlogin DESC;

-- Functions
CREATE
OR REPLACE FUNCTION get_all_fleets_path_from_root (accountidarg uuid) RETURNS TABLE (
    accountid uuid,
    fleetid uuid,
    fleetname text,
    path text
) LANGUAGE sql AS $$
with recursive children as (
    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, ft.name as path, 1 as height from fleet_tree ft
    JOIN account_fleet af ON ft.accountid = af.accountid AND ft.fleetid = af.fleetid
    where ft.accountid = accountidarg and af.isroot = true

    union all

    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, c.path || '/' || ft.name as path,
           c.height + 1 from fleet_tree ft
    join children c on ft.accountid = c.accountid and c.fleetid = ft.pfleetid
)
select c.accountid, c.fleetid, c.name as fleetname, c.path from children c
    order by height
$$;

CREATE
OR REPLACE FUNCTION get_all_fleets_path_from_root (accountidarg uuid, useridarg uuid) RETURNS TABLE (
    accountid uuid,
    fleetid uuid,
    fleetname text,
    path text,
    isroot boolean,
    createdat timestamptz,
    createdby uuid
) LANGUAGE sql AS $$
with recursive children as (
    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, ft.name as path, 1 as height from fleet_tree ft
    JOIN user_fleet uf ON ft.accountid = uf.accountid AND ft.fleetid = uf.fleetid
    where ft.accountid = accountidarg and uf.userid = useridarg

    union all

    select ft.accountid, ft.pfleetid, ft.fleetid, ft.name, c.path || '/' || ft.name as path,
           c.height + 1 from fleet_tree ft
    join children c on ft.accountid = c.accountid and c.fleetid = ft.pfleetid
)
select c.accountid, c.fleetid, c.name as fleetname, c.path, af.isroot, af.createdat, af.createdby from children c
    JOIN account_fleet af ON c.accountid = af.accountid AND c.fleetid = af.fleetid
    order by height
$$;



CREATE OR REPLACE FUNCTION populate_module_history()
RETURNS void
LANGUAGE plpgsql
AS $$
DECLARE
    module_record RECORD;
    current_state_jsonb jsonb;
BEGIN
    -- Clear existing data 
    -- DELETE FROM module_history;
    
    -- Loop through each module
    FOR module_record IN 
        SELECT 
            moduleid,
            modulename,
            moduletype,
            modulecode,
            moduleinfo,
            creditspervehicleday,
            priority,
            isenabled,
            createdat,
            createdby
        FROM module
    LOOP
        -- Build current state as jsonb object
        current_state_jsonb := jsonb_build_object(
            'moduleid', module_record.moduleid,
            'modulename', module_record.modulename,
            'moduletype', module_record.moduletype,
            'modulecode', module_record.modulecode,
            'moduleinfo', module_record.moduleinfo,
            'creditspervehicleday', module_record.creditspervehicleday,
            'priority', module_record.priority,
            'isenabled', module_record.isenabled
        );
        
        -- Insert history data for this module
        INSERT INTO module_history (
            moduleid,
            modulename,
            moduletype,
            modulecode,
            moduleinfo,
            creditspervehicleday,
            priority,
            isenabled,
            updatedat,
            updatedby,
            action,
            previousstate,
            currentstate
        ) VALUES (
            module_record.moduleid,
            module_record.modulename,
            module_record.moduletype,
            module_record.modulecode,
            module_record.moduleinfo,
            module_record.creditspervehicleday,
            module_record.priority,
            module_record.isenabled,
            module_record.createdat,  -- Use createdat as updatedat for initial entry
            module_record.createdby,  -- Use createdby as updatedby for initial entry
            'CREATE',                 -- Action type for initial creation
            '{}'::jsonb,              -- Empty previous state (no previous state for initial creation)
            current_state_jsonb       -- Current state with all module fields
        );
        
    END LOOP;
    
    RAISE NOTICE 'Module history populated successfully';
END;
$$;

-- Execute the function
SELECT populate_module_history();


CREATE OR REPLACE FUNCTION populate_package_history()
RETURNS void
LANGUAGE plpgsql
AS $$
DECLARE
    package_record RECORD;
    current_state_jsonb jsonb;
BEGIN
    -- Clear existing data 
    -- DELETE FROM package_history;
    
    -- Loop through each package
    FOR package_record IN 
        SELECT 
            pkgid,
            pkgname,
            pkgtype,
            pkginfo,
            isenabled,
            createdat,
            createdby
        FROM package
    LOOP
        -- Build current state as jsonb object
        current_state_jsonb := jsonb_build_object(
            'pkgid', package_record.pkgid,
            'pkgname', package_record.pkgname,
            'pkgtype', package_record.pkgtype,
            'pkginfo', package_record.pkginfo,
            'isenabled', package_record.isenabled
        );
        
        -- Insert history data for this package
        INSERT INTO package_history (
            pkgid,
            pkgname,
            pkgtype,
            pkginfo,
            isenabled,
            updatedat,
            updatedby,
            action,
            previousstate,
            currentstate
        ) VALUES (
            package_record.pkgid,
            package_record.pkgname,
            package_record.pkgtype,
            package_record.pkginfo,
            package_record.isenabled,
            package_record.createdat,  -- Use createdat as updatedat for initial entry
            package_record.createdby,  -- Use createdby as updatedby for initial entry
            'CREATE',                 -- Action type for initial creation
            '{}'::jsonb,              -- Empty previous state (no previous state for initial creation)
            current_state_jsonb       -- Current state with all package fields
        );
        
    END LOOP;
    
    RAISE NOTICE 'Package history populated successfully';
END;
$$;

-- Execute the function
SELECT populate_package_history();