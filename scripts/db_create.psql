        FOREIGN KEY (accountid, fleetid) REFERENCES account_fleet (accountid, fleetid),
        FOREIGN KEY (createdby) REFERENCES users (userid),
        FOREIGN KEY (updatedby) REFERENCES users (userid)
    );

